# .env.local — 실제 값 입력 후 이 파일을 .env.local로 복사해서 사용
# ⚠️ .env.local은 절대 커밋하지 말 것 (.gitignore 확인)

# ── Cloudflare R2 (scripts/11-photo-era.ts + 향후 api/og) ──────────────────

# Cloudflare 대시보드 → R2 → 버킷 선택 → 설정 → Account ID
R2_ACCOUNT_ID=

# Cloudflare 대시보드 → R2 → 개요 → "API 토큰 관리" → 토큰 생성 (Object Read & Write)
# → Access Key ID
R2_ACCESS_KEY_ID=

# 위 토큰 생성 시 발급되는 Secret Access Key (생성 직후 1회만 표시 — 반드시 복사)
R2_SECRET_ACCESS_KEY=

# 사용할 R2 버킷 이름 (Cloudflare 대시보드에서 생성한 버킷명 그대로 입력)
R2_BUCKET=

# 버킷의 공개 URL (R2 → 버킷 → 설정 → 공개 액세스 활성화 후 표시되는 URL, 끝 슬래시 없이)
# 예: https://pub-xxxx.r2.dev  또는  https://assets.yourdomain.com
R2_PUBLIC_BASE_URL=

# ── Next.js 프론트 (PlayerCard 결정론적 사진 URL) ──────────────────────────
# 위 R2_PUBLIC_BASE_URL과 동일 값 — NEXT_PUBLIC_ 접두어로 빌드 시 번들에 인라인됨
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# ── 사진 킬스위치 (§5) ─────────────────────────────────────────────────────
# "false" 로 설정하면 전원 아바타 폴백 (기본값: 사진 활성)
# NEXT_PUBLIC_PHOTOS_ENABLED=false
